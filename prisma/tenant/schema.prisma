// Avelior Analytics — TENANT-DATA schema (MongoDB, one DB per tenant).
// Models map the "CRM Chris" prospecting spreadsheet (French insurance brokers).
//
// This client keeps the DEFAULT @prisma/client output so existing imports
// (`import { ... } from "@prisma/client"`) are unchanged. At runtime the DB
// router (src/lib/tenant-db.ts) instantiates one client per tenant connection
// string; DATABASE_URL below is only the generate-time / tenant-#1 fallback.
//
// Auth (User/Role) lives in the CONTROL plane (prisma/control/schema.prisma),
// so Activity.userId here is a loose id with no cross-DB relation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Priorite {
  A
  B
  C
}

enum Potentiel {
  FAIBLE
  MOYEN
  FORT
}

// Core prospect entity — one row per SIRET (establishment) in the source sheet.
model Company {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  siren               String?
  siret               String    @unique
  nomSociete          String?
  enseigne            String?
  categorieEntreprise String?
  formeJuridique      String?
  dateCreation        DateTime?
  codeNaf             String?
  libelleNaf          String?
  trancheEffectifs    String?
  adresse             String?
  codePostal          String?
  ville               String?
  siteWeb             String?
  emailGenerique      String?
  telephoneStandard   String?
  chiffreAffaires     Int?
  canalPrefere        String? // PHONE | EMAIL | LINKEDIN — preferred way to reach the prospect

  // Specialties (booleans for easy filtering)
  specialiteSante        Boolean @default(false)
  specialitePrevoyance   Boolean @default(false)
  specialiteIard         Boolean @default(false)
  specialiteAuto         Boolean @default(false)
  specialiteRcPro        Boolean @default(false)
  specialiteEntreprises  Boolean @default(false)
  specialiteCollectives  Boolean @default(false)
  specialiteParticuliers Boolean @default(false)

  // Scoring / qualification
  nbCollaborateursEstime Int?
  niveauDigitalisation   String?
  icpScore               Int?
  priorite               Priorite?
  potentiel              Potentiel?

  // Pipeline tracking. Was a Prisma enum; now config-driven (StageDefinition) —
  // Mongo always stored it as a plain string, so this is a type-only change.
  stage              String        @default("A_QUALIFIER")
  canal              String?
  datePremierContact DateTime?
  dernierContact     DateTime?
  relancePrevue      DateTime?
  demoRealisee       Boolean       @default(false)
  propositionEnvoyee Boolean       @default(false)
  closingEstime      DateTime?
  notes              String?

  // Tenant-defined custom fields (Phase-1 "config, not code"). Flexible document
  // keyed by FieldDefinition.key — new fields need no schema migration.
  customFields Json?

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  contacts    Contact[]
  activities  Activity[]
  tasks       Task[]
  deals       Deal[]
  enrollments Enrollment[]
  outreachMessages OutreachMessage[]
  financeEntries FinanceEntry[]
  stageChanges StageChange[]

  @@index([stage])
  @@index([ville])
  @@index([priorite])
  @@index([codePostal])
}

// Opportunity / affaire — a company can be re-prospected across renewals and
// products (santé this year, prévoyance next), so stage lives on a Deal, not only
// on Company. One deal per company is flagged `isPrimary` and mirrors the company's
// pipeline stage (the board stays company-keyed); additional deals track parallel
// or historical opportunities. `stage`/`status` are strings (config-friendly,
// mirror the PipelineStage values), matching the Task/Activity convention.
model Deal {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  companyId String    @db.ObjectId
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title     String    @default("Opportunité")
  stage     String    @default("A_QUALIFIER")
  product   String? // e.g. Santé, Prévoyance, IARD
  amount    Int? // estimated annual value, in euros
  status    String    @default("OPEN") // OPEN | WON | LOST
  isPrimary Boolean   @default(true) // the deal mirrored on the pipeline board
  closeDate DateTime?
  customFields Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([companyId])
  @@index([stage])
  @@index([status])
}

// Business cost / income ledger — the "Finances cockpit". One flexible model
// covers all four kinds the owner pilots by, distinguished by `kind` + the
// money `direction` (mirrors how Deal/Activity carry type-specific nullable
// fields rather than splitting into many tables):
//   SUBSCRIPTION — recurring software (with free-trial + renewal tracking)
//   STAFF        — recurring people cost (salary / freelancer retainer)
//   EXPENSE      — one-off spend or supplier bill
//   INVOICE      — money billed to a client (direction = IN)
// `amount` is euros (Int, matching Deal.amount / Company.chiffreAffaires).
// `category` is config-driven (FieldDefinition entity "FINANCE", a select).
// trialEndsAt / renewsAt / dueDate seed Task alerts via lib/finance-alerts.ts.
model FinanceEntry {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  direction    String    @default("OUT") // OUT = cost | IN = income
  kind         String    @default("EXPENSE") // SUBSCRIPTION | STAFF | EXPENSE | INVOICE
  label        String
  vendor       String? // supplier (cost) or client (invoice)
  category     String?
  amount       Int       @default(0) // euros
  currency     String    @default("EUR")
  recurrence   String    @default("NONE") // NONE | MONTHLY | QUARTERLY | ANNUAL
  status       String    @default("ACTIVE") // cost: ACTIVE|TRIAL|PAUSED|CANCELLED ; invoice: DRAFT|SENT|PAID|OVERDUE
  date         DateTime? // one-off spend date / invoice issue date
  startDate    DateTime? // subscription / engagement start
  endDate      DateTime? // engagement end / cancellation date
  trialEndsAt  DateTime? // free-trial end → alert
  renewsAt     DateTime? // next billing/renewal → alert
  dueDate      DateTime? // invoice due → alert if unpaid
  autoRenew    Boolean   @default(true)
  notes        String?
  // Optional link to a CRM Company (the client on an invoice, or a vendor that
  // is also a prospect). SetNull on delete — losing the company doesn't lose the
  // ledger entry.
  companyId    String?   @db.ObjectId
  company      Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  customFields Json? // self-serve custom fields (no migration), keyed by FieldDefinition.key
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([direction, status])
  @@index([kind])
  @@index([renewsAt])
  @@index([trialEndsAt])
  @@index([dueDate])
  @@index([date])
  @@index([companyId])
}

// Small tenant key/value store for single scalar settings that don't warrant
// their own model — e.g. "finance.cashOnHand" (trésorerie) backing the cockpit
// runway figure. Value is a string; callers coerce. Upserted by `key`.
model Setting {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// Tenant-defined custom field on a CRM entity — the Phase-1 config store. New
// fields are added here as DATA (not code) and read/written on each entity's
// flexible `customFields` document, so adding a field needs no schema migration.
//
// `source` distinguishes the two kinds of field this collection now describes:
// "CUSTOM" (read/written via the entity's flexible `customFields` Json, the
// original Phase-1 design — user-deletable in Phase 2) vs "NATIVE" (metadata
// about an existing scalar column, e.g. `nomSociete` — `key` is the Prisma
// field name; read/written via the real column, never via `customFields`, and
// never user-deletable since the column itself isn't config). `section` groups
// fields for rendering (e.g. "Identité", "Coordonnées", "Qualification").
model FieldDefinition {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  entity     String // COMPANY | CONTACT | DEAL
  key        String // stable key: customFields key (CUSTOM) or scalar column name (NATIVE)
  label      String
  type       String   @default("text") // text | number | select | bool | date
  options    String[] @default([]) // choices when type == "select"
  required   Boolean  @default(false)
  showInForm Boolean  @default(true)
  order      Int      @default(0)
  source     String   @default("CUSTOM") // CUSTOM | NATIVE
  section    String   @default("") // form grouping label, e.g. "Identité"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([entity, key])
  @@index([entity])
}

// Pipeline stage, as config data (Phase-1 follow-up — was a Prisma enum +
// hardcoded `PIPELINE_STAGES` array in src/lib/constants.ts). `key` is the
// value stored in Company.stage / Deal.stage; `accentClass`/`badgeClass`/
// `dotClass` are the Tailwind classes previously baked into StageMeta.
model StageDefinition {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  key         String   @unique
  label       String
  order       Int      @default(0)
  accentClass String   @default("")
  badgeClass  String   @default("")
  dotClass    String   @default("")
  isWon       Boolean  @default(false)
  isLost      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Multi-touch outreach cadence (config). `steps` is an ordered JSON array of
// { offsetDays, channel (EMAIL|APPEL|LINKEDIN), title, subject?, body? }.
// Companies are enrolled (Enrollment). `mode` decides who owns due steps:
//   TASKS      — the cron materializes each due step as a Task (original behavior)
//   AUTO_EMAIL — the outreach send engine emails EMAIL steps itself (subject/body
//                templates; delays are in BUSINESS days) and only materializes
//                the non-email channels (APPEL/LINKEDIN) as Tasks.
model Sequence {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  steps       Json // [{ offsetDays, channel, title, subject?, body? }]
  mode        String       @default("TASKS") // TASKS | AUTO_EMAIL
  active      Boolean      @default(true)
  enrollments Enrollment[]
  outreachMessages OutreachMessage[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// A company's progression through a Sequence. `currentStep` is the index of the
// next step to materialize; `nextDueAt` is when it's due (anchored on createdAt +
// the step's offsetDays). The cron advances ACTIVE enrollments whose step is due.
// AUTO_EMAIL terminal statuses: REPLIED (prospect answered — immediate exit),
// BOUNCED (address dead), OPTED_OUT (unsubscribe link clicked).
model Enrollment {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  companyId   String    @db.ObjectId
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId   String?   @db.ObjectId
  sequenceId  String    @db.ObjectId
  sequence    Sequence  @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  status      String    @default("ACTIVE") // ACTIVE | PAUSED | DONE | REPLIED | BOUNCED | OPTED_OUT
  currentStep Int       @default(0)
  nextDueAt   DateTime?
  outreachMessages OutreachMessage[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, nextDueAt])
  @@index([companyId])
}

// One row per cold email actually sent by the outreach engine — the engine's
// source of truth (threading, caps, metrics). Each send is ALSO logged as an
// OUTBOUND EMAIL Activity for the human timeline; this ledger keeps the fields
// the engine needs that Activity doesn't carry (RFC Message-ID chain for
// In-Reply-To/References, Gmail threadId for reply matching, bounce status).
model OutreachMessage {
  id             String     @id @default(auto()) @map("_id") @db.ObjectId
  enrollmentId   String     @db.ObjectId
  enrollment     Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  companyId      String     @db.ObjectId
  company        Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId      String?    @db.ObjectId
  sequenceId     String     @db.ObjectId
  sequence       Sequence   @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  stepIndex      Int
  toEmail        String
  subject        String
  body           String
  messageId      String // RFC Message-ID we stamped (threading + sync dedupe)
  gmailMessageId String?
  gmailThreadId  String?
  status         String     @default("SENT") // SENT | BOUNCED
  sentAt         DateTime   @default(now())

  @@index([gmailThreadId])
  @@index([sentAt])
  @@index([enrollmentId])
  @@index([companyId])
}

// Outreach engine settings — one row per tenant (upserted by key-less singleton
// convention: first row wins, created with defaults on first read). Typed model
// rather than Setting key/value rows because the send engine reads all of it on
// every run and the numbers gate real-world sending behavior.
model OutreachConfig {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  dailyCap            Int       @default(25) // hard ceiling, post warm-up
  rampStartDate       DateTime? // when warm-up began; null = no ramp, use dailyCap
  rampStartCap        Int       @default(5) // cap during week 1 of the ramp
  rampWeeklyIncrement Int       @default(5) // cap += this per elapsed week
  sendWindowStart     String    @default("09:00") // Europe/Paris, business days only
  sendWindowEnd       String    @default("17:30")
  skipHolidays        Boolean   @default(true) // French public holidays
  bounceThresholdPct  Int       @default(5) // trailing-7d bounce % that trips the breaker
  paused              Boolean   @default(false)
  pausedReason        String?
  pausedAt            DateTime?
  autoEnrollSequenceId String?  @db.ObjectId // Lead One approve → auto-enroll target
  unsubscribeText     String    @default("Pour ne plus recevoir nos messages :")
  updatedAt           DateTime  @updatedAt
}

// People attached to a company (dirigeants).
model Contact {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  nom         String?
  prenom      String?
  fonction    String?
  email       String?
  // Deliverability verdict on `email`, set by the outreach engine: "INVALID"
  // after a hard bounce (mirrors LeadCandidate.emailStatus vocabulary). Null =
  // never tested. Enrollment guards refuse INVALID addresses.
  emailStatus String?
  telephone   String?
  linkedinUrl String?
  isDecisionMaker Boolean? @default(false)
  customFields Json?
  // RGPD consent for prospecting outreach: "OPT_IN" | "OPT_OUT" | null (unknown).
  consent   String?
  consentAt DateTime?
  companyId   String     @db.ObjectId
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activities  Activity[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([companyId])
}

// Interaction log — calls, emails, meetings, notes, stage changes.
model Activity {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  type      String // CALL | EMAIL | MEETING | NOTE | STAGE_CHANGE
  note      String?
  body      String? // fuller raw text (email body, meeting/call summary) for AI
  date      DateTime @default(now())
  // Email-sync fields (populated when type == EMAIL)
  direction String? // INBOUND | OUTBOUND
  subject   String?
  fromEmail String?
  toEmail   String?
  messageId String? // dedupe key: RFC Message-ID, cal:<uid>, or ff:<transcript>
  // AI insight (filled by the Claude pass in lib/ai-extract)
  aiSummary      String?
  sentiment      String? // POSITIF | NEUTRE | NEGATIF
  nextStep       String?
  actionItems    String? // JSON array of strings
  suggestedStage String? // a PipelineStage value, surfaced as a suggestion
  companyId String?  @db.ObjectId
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId String?  @db.ObjectId
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  // Author of the activity. Loose id into the CONTROL-plane User (no cross-DB relation).
  userId    String?  @db.ObjectId
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([date])
  @@index([messageId])
}

// Follow-up / to-do attached to a company. The "system of action" layer:
// manual relances + tasks auto-seeded from an Activity's AI `nextStep`.
// Type/source kept as strings (not Prisma enums) to mirror Activity.type and
// stay config-friendly.
model Task {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  title      String
  type       String    @default("RELANCE") // RELANCE | APPEL | EMAIL | RDV | AUTRE
  dueDate    DateTime?
  done       Boolean   @default(false)
  doneAt     DateTime?
  note       String?
  source     String    @default("MANUAL") // MANUAL | AI_NEXTSTEP | FINANCE
  // When source == AI_NEXTSTEP, the Activity it was derived from — dedupe key so
  // re-running the enrichment pass never creates a duplicate task.
  activityId String?   @db.ObjectId
  // When source == FINANCE, the FinanceEntry whose trial/renewal/due date seeded
  // this task — dedupe key so the cron never creates a duplicate finance alert.
  financeEntryId String? @db.ObjectId
  // companyId is OPTIONAL: prospecting tasks attach to a company, but finance
  // alerts (trial ends, renewals, invoices due) have no company. toggleTask only
  // logs an activity when companyId is set, so company-less tasks are a no-op there.
  companyId  String?   @db.ObjectId
  company    Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // Loose ids into the tenant Contact / control-plane User (no cross-DB relation),
  // matching the Activity.userId convention.
  contactId  String?   @db.ObjectId
  userId     String?   @db.ObjectId
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([done, dueDate])
  @@index([companyId])
  @@index([activityId])
  @@index([financeEntryId])
}

// Review queue for email addresses seen in synced mail that don't match a
// known contact and can't be auto-attached to a company by domain.
model PendingContact {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  email         String   @unique
  name          String?
  direction     String? // last seen direction
  sampleSubject String?
  messageCount  Int      @default(1)
  firstSeen     DateTime @default(now())
  lastSeen      DateTime @default(now())
  status        String   @default("PENDING") // PENDING | APPROVED | DISMISSED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
}

// Permanent block list fed by the inbox "Spam" action. The email sync consults
// this so a blocked address OR domain never re-enters the CRM (no contact, no
// activity, no queue entry) — even if they mail again.
model BlockedSender {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  value     String   @unique // lowercased email address OR bare domain
  kind      String // "EMAIL" | "DOMAIN"
  createdAt DateTime @default(now())

  @@index([kind])
}

// Incremental sync checkpoint, one row per IMAP mailbox path. (Legacy IMAP path.)
model EmailSyncState {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  mailbox   String   @unique // e.g. "INBOX" or "[Gmail]/Sent Mail"
  lastUid   Int      @default(0)
  updatedAt DateTime @updatedAt
}

// Incremental sync cursor for the Google APIs (string tokens, unlike the IMAP
// UID): "gmail" stores the Gmail historyId, "calendar" the events.list syncToken.
model SyncCursor {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  source    String   @unique // "gmail" | "calendar"
  cursor    String?
  updatedAt DateTime @updatedAt
}

// Append-only audit trail (P2.4 RGPD): who did what to which record, written
// by lib/audit.ts for destructive / PII-relevant actions (erase, export,
// merges, deletions). Read-only viewer at /settings/audit.
model AuditLog {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  at       DateTime @default(now())
  userId   String? // control-plane user id
  action   String // e.g. "RGPD_ERASE" | "RGPD_EXPORT" | "MERGE_COMPANIES" | "DELETE_COMPANY"
  entity   String // "COMPANY" | "CONTACT" | …
  entityId String?
  details  String? // human-readable summary (never raw PII beyond what's needed)

  @@index([at])
}

// Append-only log of pipeline stage transitions (P2.3 Analytics v2: stage
// velocity, stage-to-stage conversion, win-rate trend). `from` is null for the
// initial stage at creation. Written by lib/stage-history.ts from every path
// that changes Company.stage.
model StageChange {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId String   @db.ObjectId
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  from      String?
  to        String
  at        DateTime @default(now())
  userId    String? // control-plane user id, when a human made the change

  @@index([companyId, at])
  @@index([to, at])
}

// ── Lead One — automated lead-gen pipeline (staging, kept OUT of Company) ────
// Raw leads sourced from recherche-entreprises (NAF 66.22Z), enriched by the
// quota-gated website search + site crawler, validated, then promoted into
// Company/Contact via lib/leadone/promote. Deliberately minimal fields: no
// address/city/legal metadata (departement is only the sourcing segment key).
model LeadCandidate {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  siren      String?
  siret      String  @unique // dedup key, same as Company
  nomSociete String?
  enseigne   String?
  departement String? // 2-char sourcing segment — never surfaced, never promoted

  siteWeb     String?
  email       String?
  emailKind   String? // NOMINATIVE | GENERIC | NONE
  emailStatus String? // MX_VALID | SYNTAX_ONLY | INVALID
  telephone   String? // normalized FR format
  dirigeants  Json? // [{ nom, prenom, qualite }] from the registry
  specialites Json? // { sante, prevoyance, iard, auto, rcPro, entreprises, collectives, particuliers }

  // SOURCED → ENRICHED_WEBSITE → ENRICHED_CONTACT → VALIDATED → PROMOTED | REJECTED
  status     String @default("SOURCED")
  confidence Int    @default(0) // 0–100 (lib/leadone/validate scoreCandidate)
  provenance Json? // per-field source+timestamp, e.g. { siteWeb: { src: "tavily", at } } — legacy rows may carry "google_cse"
  attempts   Json? // { website: n, contact: n } — reject after 3 dead-end tries
  lastError  String?

  promotedCompanyId String? @db.ObjectId // loose ref, set on promotion
  reviewedBy        String? // control-plane user id (loose, like Activity.userId)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, updatedAt])
  @@index([departement])
  @@index([confidence])
}

// Per-provider free-tier budget. The orchestrator consumes via takeQuota() and
// resets `used` when the window (DAILY / MONTHLY) has elapsed — this is what
// makes the pipeline auto-resume when a free tier refreshes.
model LeadOneQuota {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  provider    String   @unique // "tavily" | "exa" | "hunter" | "serpapi"
  used        Int      @default(0)
  limit       Int // 1000 (Tavily/mo) | 1000 (Exa/mo) | 25 (Hunter/mo) | 250 (SerpApi/mo)
  window      String // "DAILY" | "MONTHLY"
  windowStart DateTime
  updatedAt   DateTime @updatedAt
}

// One row per pipeline execution — observability for the /leadone page and CI.
model LeadOneRun {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  trigger    String    @default("CRON") // CRON | MANUAL
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  stats      Json? // { sourced, websitesFound, crawled, validated, promoted, purged, quota }
  error      String?

  @@index([startedAt])
}

// A saved filter set on a list page (P2.2 "saved views"). Per-user: the URL
// querystring of the page's live filters is stored verbatim, so applying a
// view is just navigation — no filter schema duplicated here.
model SavedView {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String // control-plane user id (like Activity.userId)
  page      String // "companies" | "contacts"
  name      String
  query     String // serialized querystring, e.g. "stage=RDV_PLANIFIE&priorite=A"
  createdAt DateTime @default(now())

  @@index([userId, page])
}

// ── Heimdallr — agentic platform foundation (S2/S3) ─────────────────────────
// Designed in docs/mimir/events.md; implemented verbatim here. Four models:
// AgentEvent (append-only stream), AgentAction (the one ledger, D5),
// AutonomyConfig (per-category autonomy level + breaker, D2), PromptTemplate
// (prompts as tenant config, Path C rule 1). See events.md for the full
// taxonomy, state machine, and rules — this is the schema only.

model AgentEvent {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  at       DateTime @default(now())
  module   String   // heimdallr | mimisbrunnr | huginn | muninn | nornir | bragi | forseti | system
  category String   // AutonomyConfig.category key, or module-local domain (ingestion, quota, …)
  action   String   // lifecycle verb — see events.md §1
  actionId String?  @db.ObjectId // loose ref → AgentAction
  runId    String?  // loose ref → queue job/run (run model decided at S4)
  entity   String?  // COMPANY | CONTACT | DEAL | … (AuditLog convention)
  entityId String?  @db.ObjectId
  userId   String?  @db.ObjectId // loose ref → control-plane User (approver/editor), no relation
  data     Json?    // small event-specific payload; big blobs live on AgentAction

  @@index([at])
  @@index([module, category, at])
  @@index([actionId])
  @@index([entity, entityId])
}

model AgentAction {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  module   String // emitting module (same vocabulary as AgentEvent.module)
  category String // autonomy category key → AutonomyConfig
  type     String // concrete action, e.g. email.draft_reply | crm.update_field | doc.rca
  status   String @default("PROPOSED")
  // PROPOSED | APPROVED | REJECTED | EXPIRED | EXECUTED | FAILED | UNDONE

  payload       Json    // the proposal as generated (draft body, field diff, doc content, …)
  editedPayload Json?   // payload after human edit; null = approved untouched
  wasEdited     Boolean @default(false) // denormalized for graduation queries

  sources Json? // cited passages: [{ docId, chunkId, quote, score }] (Mímisbrunnr, S12)
  trigger Json? // triggering context: { kind: "email"|"cron"|"manual", refs… }
  entity   String?
  entityId String? @db.ObjectId

  autonomyLevelAtProposal Int  // level in force when proposed — graduation-stat integrity
  promptKey     String?       // PromptTemplate key used to generate the proposal
  promptVersion Int?          // + exact version — pins what produced this output

  reversible Boolean   @default(false)
  undoData   Json?     // whatever execution recorded to reverse itself
  expiresAt  DateTime? // auto-EXPIRED past this (stale drafts don't linger as pending)

  proposedAt DateTime  @default(now())
  decidedAt  DateTime?
  decidedBy  String?   @db.ObjectId // loose ref → control-plane User; null = auto-approved
  executedAt DateTime?
  undoneAt   DateTime?
  error      String?

  @@index([status, proposedAt])
  @@index([category, status])
  @@index([entity, entityId])
}

model AutonomyConfig {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  category String @unique // dotted key, e.g. huginn.support_reply
  label    String // French label — config-as-data, StageDefinition pattern
  level    Int    @default(0) // 0 off | 1 draft_approve | 2 auto_with_undo | 3 autonomous
  maxLevel Int    @default(3) // ceiling; never-graduates categories seeded with 1

  // graduation + breaker thresholds (OutreachConfig pattern)
  editRateThresholdPct       Int @default(20) // trailing edit-rate that trips demotion
  negativeSignalThresholdPct Int @default(5)  // module-defined negative signal (bounce pattern)
  breakerMinSample           Int @default(10) // below this, breaker/graduation stay silent
  graduationWindowDays       Int @default(21)
  graduationUneditedPct      Int @default(95) // D2: ≥95% unedited over the window

  undoWindowMinutes Int @default(60)

  // kill switch (OutreachConfig paused-triple)
  paused       Boolean   @default(false)
  pausedReason String?
  pausedAt     DateTime?

  updatedAt DateTime @updatedAt
}

model PromptTemplate {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   // dotted, e.g. huginn.support_reply.draft
  version   Int      @default(1)
  label     String   // French label
  body      String   // template text with {{placeholders}}
  variables String[] @default([]) // declared placeholder names — render fails on undeclared vars
  taskClass String   // classify | extract | draft | summarize — S5 router maps class → model
  module    String?  // owning module, for admin UI grouping
  active    Boolean  @default(true) // exactly one active version per key (enforced in code, S7 API)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, version])
  @@index([key, active])
}
