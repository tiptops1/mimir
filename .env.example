# --- Avelior Analytics environment variables ---

# === Multi-tenancy (Phase 0 spine) ===
# Tenant #1's data DB (Christopher). This is also the DB the SESSION-LESS
# contexts (the /api/cron route + sync scripts) use directly in Phase 0 —
# ingestion is single-tenant by design until Phase 3 routes it per tenant.
# Format: mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/crm_chris?retryWrites=true&w=majority
DATABASE_URL=

# Control-plane DB (tenants, users, memberships). A SEPARATE database on the
# SAME cluster as the tenant DBs. Created by `npm run tenant:bootstrap`.
# Format: mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/crm_control?retryWrites=true&w=majority
CONTROL_DATABASE_URL=

# Base connection string used to derive a NEW tenant's DB during provisioning:
# the DB-name path is swapped for the tenant slug. Point it at the shared cluster.
# Format: mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
CLUSTER_BASE_URL=

# AES-256-GCM key for secrets at rest in the control plane (tenant connection
# strings + Google OAuth refresh tokens). 32 bytes, base64. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# Slug of tenant #1 (the bootstrap default). Used by the SESSION-LESS contexts
# (/api/cron + sync scripts) to resolve tenant #1's Google credential. Defaults
# to "crm_chris" if unset.
TENANT1_SLUG=crm_chris

# Vendor login email(s), comma-separated — unlocks the /settings/tenants page
# (Phase 4 self-serve tenant provisioning). Tenant ADMINs (e.g. Christopher)
# must NOT be listed: creating tenants is a platform capability, not a tenant one.
PLATFORM_ADMIN_EMAILS=

# Secret used to sign session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# Public base URL of the app (used for cookies/links in production).
# Example on Railway: https://avelior-analytics.up.railway.app
APP_URL=http://localhost:3000

# NOTE: admin/login accounts now live in the CONTROL plane and are created by
# the provisioning scripts (`tenant:bootstrap` adopts the existing admin;
# `tenant:provision --admin-email/--admin-password` for new tenants). `npm run
# seed` only loads tenant DATA (companies/contacts) now — these are unused.
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=
# SEED_ADMIN_NAME=

# --- Optional website-discovery keys (enrichment) ---
# Brave Search API — free tier 2k/month (https://brave.com/search/api/).
# Most reliable free way to auto-find company websites. Recommended.
BRAVE_API_KEY=

# Pappers API (https://www.pappers.fr/api) — now a paid plan. Optional.
PAPPERS_API_KEY=

# --- Google integration (Gmail + Calendar) via OAuth — PREFERRED ---
# The seamless "Connect Google" flow. One app registration (Web application
# OAuth client) serves the platform; each tenant connects from the dashboard and
# its refresh token is stored encrypted in the control plane.
#
# Set up in Google Cloud (see INTEGRATIONS.md): create a project, enable the
# Gmail API + Google Calendar API, configure the OAuth consent screen (Internal
# if the account is on a Google Workspace domain — no verification + non-expiring
# tokens), and create a Web-application OAuth client. Add the redirect URIs:
#   http://localhost:3000/api/integrations/google/callback   (dev)
#   https://<app>/api/integrations/google/callback           (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# --- LEGACY email sync (Gmail / Workspace over IMAP) — fallback only ---
# Used only if the tenant has NOT connected a Google account via OAuth above.
# Requires 2-Step Verification + an App Password, and IMAP enabled in Gmail.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=Ctoppo@avelior.eu
IMAP_PASSWORD=
# Whose mailbox this is (defaults to IMAP_USER) — used to tell sent vs received.
OWNER_EMAIL=Ctoppo@avelior.eu

# --- AI insight ---
# Powers the "smart" layer: reads each email / meeting / call and extracts a
# summary, sentiment, next step and suggested pipeline stage. Without any key
# below the pipeline still logs activities — they just won't carry AI insight.
# Provider selection: GEMINI_API_KEY is used if set, otherwise ANTHROPIC_API_KEY.
#
# Option A (recommended — FREE): Google Gemini free tier. At ~10-15 interactions
# a day this stays well inside the free quota. Get a key at
# https://aistudio.google.com/apikey (can reuse the same Google account/project
# as the Gmail/Calendar integration above).
GEMINI_API_KEY=
# Optional model override (defaults to gemini-2.5-flash).
GEMINI_MODEL=
#
# Option B (fallback — usage-based, a few €/month here): Anthropic Claude.
# Get a key at https://console.anthropic.com. Only used if GEMINI_API_KEY is unset.
ANTHROPIC_API_KEY=
# Optional model override (defaults to a cheap, fast Haiku model).
ANTHROPIC_MODEL=

# --- LEGACY Google Calendar (secret iCal, no OAuth) — fallback only ---
# Used only if no Google account is connected via OAuth (GOOGLE_* above).
# In Google Calendar: Settings → [your calendar] → Integrate calendar →
# "Secret address in iCal format". Paste that .ics URL here. Read-only.
GOOGLE_CALENDAR_ICS_URL=

# --- Fireflies.ai (call transcripts) ---
# API key from Fireflies → Settings → Integrations → API (Developer settings).
FIREFLIES_API_KEY=

# --- Scheduler ---
# Shared secret protecting /api/cron. Generate with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# Then schedule an hourly request:
#   curl -H "Authorization: Bearer $CRON_SECRET" https://<app>/api/cron
CRON_SECRET=
