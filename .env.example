# --- Avelior Analytics environment variables ---

# MongoDB connection string (Atlas replica set recommended).
# Format: mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/avelior?retryWrites=true&w=majority
DATABASE_URL=

# Secret used to sign session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# Public base URL of the app (used for cookies/links in production).
# Example on Railway: https://avelior-analytics.up.railway.app
APP_URL=http://localhost:3000

# Default admin account created by `npm run seed`
SEED_ADMIN_EMAIL=christopher@avelior.com
SEED_ADMIN_PASSWORD=ChangeMe!2026
SEED_ADMIN_NAME=Christopher

# --- Optional website-discovery keys (enrichment) ---
# Brave Search API — free tier 2k/month (https://brave.com/search/api/).
# Most reliable free way to auto-find company websites. Recommended.
BRAVE_API_KEY=

# Pappers API (https://www.pappers.fr/api) — now a paid plan. Optional.
PAPPERS_API_KEY=
