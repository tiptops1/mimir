{
  "name": "avelior-analytics",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run prisma:generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "npm run prisma:generate",
    "prisma:generate": "prisma generate --schema=prisma/control/schema.prisma && prisma generate --schema=prisma/tenant/schema.prisma",
    "db:push": "prisma db push --schema=prisma/tenant/schema.prisma",
    "db:push:control": "prisma db push --schema=prisma/control/schema.prisma",
    "tenant:bootstrap": "tsx scripts/bootstrap-control-plane.ts",
    "tenant:provision": "tsx scripts/provision-tenant.ts",
    "deals:backfill": "tsx scripts/backfill-deals.ts",
    "config:seed": "tsx scripts/seed-config.ts",
    "user:add": "tsx scripts/add-user.ts",
    "search:indexes": "tsx scripts/create-search-indexes.ts",
    "seed": "tsx prisma/seed.ts",
    "enrich:all": "tsx prisma/enrich-all.ts",
    "enrich:websites": "tsx scripts/enrich-websites.ts",
    "sync:email": "tsx scripts/sync-email.ts",
    "sync:calendar": "tsx scripts/sync-calendar.ts",
    "sync:fireflies": "tsx scripts/sync-fireflies.ts",
    "sync:all": "tsx scripts/sync-all.ts",
    "clean:inbox": "tsx scripts/clean-inbox-spam.ts",
    "import:200-1802": "tsx scripts/dedup-and-import.ts",
    "dedup:names": "tsx scripts/dedup-by-name.ts",
    "enrich:full": "tsx scripts/enrich-full.ts",
    "enrich:dirigeants": "tsx scripts/enrich-dirigeants.ts",
    "cleanup:unnamed": "tsx scripts/delete-unnamed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "googleapis": "^173.0.0",
    "imapflow": "^1.4.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.21.0",
    "mailparser": "^3.9.10",
    "next": "16.2.9",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
